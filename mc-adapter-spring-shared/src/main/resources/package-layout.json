{
  "layoutName": "spring-package-layout",
  "layout": [
    {
      "package": "{{basePackage}}.infrastructure.config",
      "archetypes": [
        "ApplicationConfiguration",
        "DateTimeFormatConfiguration",
        "ProblemConfiguration",
        "LocalDateConverter",
        "WebMvcConfiguration",
        "WebFluxConfiguration",
        "ContainerConfiguration",
        "SecurityResponseHeadersFilter",
        "MongoContainerConfiguration",
        "BatchConfiguration",
        "JobCompletionNotificationListener",
        "KafkaAdminConfiguration",
        "KafkaConsumerConfiguration",
        "KafkaProducerConfiguration",
        "ObjectMapperConfiguration"
      ]
    },
    {
      "package": "{{basePackage}}.infrastructure.advice",
      "archetypes": [
        "GlobalExceptionHandler",
        "GlobalErrorAttributes",
        "GlobalErrorWebExceptionHandler",
        "ProblemSummary"
      ]
    },
    {
      "package": "{{basePackage}}.application.shared.exceptions",
      "archetypes": [
        "Exception",
        "BadRequestException",
        "ResourceNotFoundException",
        "UnprocessableEntityException"
      ]
    },
    {
      "package": "{{basePackage}}.adapter.inbound.web.home",
      "archetypes": [
        "RootController",
        "RootControllerExceptionHandler",
        "DefaultController"
      ]
    },
    {
      "package": "{{basePackage}}.infrastructure.profiles",
      "archetypes": [
        "SpringProfiles"
      ]
    },
    {
      "package": "{{basePackage}}.infrastructure.utils",
      "archetypes": [
        "SecureRandomSeries"
      ]
    },
    {
      "package": "{{basePackage}}.domain.shared",
      "archetypes": [
        "ResourceIdTrait",
        "ResourceIdentity"
      ]
    },
    {
      "package": "{{basePackage}}.adapter.shared.outbound",
      "archetypes": [
        "UpdateAwareConverter"
      ]
    },
    {
      "package": "{{basePackage}}.adapter.inbound.web.validation",
      "archetypes": [
        "AlphabeticAnnotation",
        "AlphabeticValidator",
        "OnCreateAnnotation",
        "OnUpdateAnnotation",
        "ResourceIdAnnotation",
        "ResourceIdValidator",
        "SearchTextAnnotation",
        "SearchTextValidator"
      ]
    },
    {
      "package": "{{basePackage}}.adapter.outbound.messaging.serdes",
      "archetypes": [
        "SerdesFactory",
        "JacksonSerializer",
        "JacksonDeserializer"
      ]
    },
    {
      "package": "{{basePackage}}.adapter.outbound.messaging.topology",
      "archetypes": [
        "Schema",
        "TopicProvisioner"
      ]
    },
    {
      "package": "{{basePackage}}.infrastructure.filter",
      "archetypes": [ "SecurityResponseHeadersFilter" ]
    },
    {
      "package": "{{basePackage}}.endpoints.{{endpoint}}.internal.persistence.converters",
      "archetypes": [
        "EndpointConfiguration"]
    },
    {
      "package": "{{basePackage}}.adapter.outbound.persistence.{{endpoint}}.converters",
      "archetypes": [
        "EndpointConfiguration",
        "EntityToPojoConverter",
        "PojoToEntityConverter",
        "PojoToDocumentConverter",
        "DocumentToPojoConverter"
      ]
    },
    {
      "package": "{{basePackage}}.endpoints.{{endpoint}}.internal.events",
      "archetypes": [
        "EntityEvent",
        "EntityEventPublisher"
      ]
    },
    {
      "package": "{{basePackage}}.infrastructure.common",
      "archetypes": [
        "AbstractIntegrationTest"
      ]
    },
    {
      "package": "{{basePackage}}",
      "archetypes": [
        "Application", "Architecture"
      ]
    },
    {
      "package": "{{basePackage}}.adapter.inbound.web.{{endpoint}}",
      "archetypes": [
        "Controller",
        "ControllerExceptionHandler",
        "Routes"
      ]
    },
    {
      "package": "{{basePackage}}.application.service",
      "archetypes": [
        "ServiceApi",
        "ServiceImpl",
        "RootService",
        "DefaultService"
      ]
    },
    {
      "package": "{{basePackage}}.adapter.inbound.web.{{endpoint}}",
      "archetypes": [
        "EntityRequest",
        "EntityResponse"
      ]
    },
    {
      "package": "{{basePackage}}.application.port.inbound.{{endpoint}}",
      "archetypes": [
        "EntityCommandUseCase",
        "EntityQueryUseCase"
      ]
    },

    {
      "package": "{{basePackage}}.endpoints.{{endpoint}}.helper",
      "archetypes": [
        "ConversionService"
      ]
    },
    {
      "package": "{{basePackage}}.common.persistence",
      "archetypes": [
        "RegisterDatabaseProperties",
        "AbstractPostgresIntegrationTest",
        "MongoDbContainerTests",
        "PostgresDbContainerTests"
      ]
    },
    {
      "package": "{{basePackage}}.application.shared.port.outbound",
      "archetypes": [
        "CustomRepository",
        "PersistenceAdapter",
        "AbstractDataStoreApi"
      ]
    },
    {
      "package": "{{basePackage}}.adapter.outbound.persistence.{{endpoint}}",
      "archetypes": [
        "DatabaseTablePopulator",
        "Document",
        "ConcreteDocumentStoreImpl",
        "AbstractDataStoreImpl",
        "Entity",
        "EntityCallback",
        "ConcreteDataStoreImpl",
        "Repository",
        "MongoDataStoreImpl",
        "TestTableInitializer",
        "TableInitializer"
      ]
    },
    {
      "package": "{{basePackage}}.application.port.outbound.{{endpoint}}",
      "archetypes": [
        "ConcreteDataStoreApi",
        "ConcreteDocumentStoreApi",
        "MongoDataStoreApi"
      ]
    },
    {
      "package": "{{basePackage}}.fixtures",
      "archetypes": [
        "EjbTestFixtures",
        "DocumentTestFixtures",
        "ModelTestFixtures",
        "PojoTestFixtures",
        "ModelTestFixtures"
      ]
    },
    {
      "package": "{{basePackage}}.application.shared.port.outbound",
      "archetypes": [ "ResourceIdSupplier" ]
    },
    {
      "package": "{{basePackage}}.domain.model",
      "archetypes": [
          "Pojo",
          "EntityResource"
      ]
    },
    {
      "package": "{{basePackage}}.adapter.outbound.persistence.{{endpoint}}.predicate",
      "archetypes": [
        "EntityWithText",
        "EntitySpecification"
      ]
    },
    {
      "package": "{{basePackage}}.misc",
      "archetypes": [ "Text", "Undefined" ]
    }
  ]
}
